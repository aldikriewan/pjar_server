# PJAR Server Configuration
# Copy file ini menjadi .env dan edit sesuai kebutuhan

# Database & File paths
# Kosongkan/komentar -> default relatif ke folder app.py (aman, tanpa root)
# Isi dengan path absolut bila ingin lokasi khusus (mis. /var/lib/pjar-web/...).
DATABASE_PATH=users.db
UPLOAD_FOLDER=uploads/received

# Flask
SECRET_KEY=change-this-to-random-secret-key

# Email (Gmail)
# Gunakan app-specific password, bukan password akun biasa
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465

# TCP Upload Server
TCP_HOST=0.0.0.0
TCP_PORT=5003

# UDP Streaming Server
UDP_HOST=0.0.0.0
UDP_PORT=5004

# Flask App
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
