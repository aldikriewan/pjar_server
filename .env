# PJAR Server Configuration
# Copy file ini menjadi .env dan edit sesuai kebutuhan

# Database & File paths
# Dikosongkan/komentar -> default relatif ke folder app.py (aman, tanpa root)
# Isi dengan path absolut bila ingin lokasi khusus.
DATABASE_PATH=users.db
UPLOAD_FOLDER=uploads/received

# Flask
SECRET_KEY=change-this-to-random-secret-key

# Email (Gmail)
